*.db
*.sqlite
*.sqlite3
*.sqlite3-journal

# === 2. STREAMLIT & DEPLOYMENT ===
# Ignore local UI secrets and environment configurations
.streamlit/secrets.toml
.streamlit/config.toml
# Temporary file for partial code execution (VS Code specific)
tempCodeRunnerFile.py

# === 3. ENVIRONMENTS & SECRETS ===
